# FinVeritas Contabolsa — Environment Variables
# Copy this file to .env and fill in real values for production.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finveritas:demo@localhost:5432/finveritas

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Security ─────────────────────────────────────────────────────────────────
# Anti-fraud / digital signature secret (rotate in production)
SIGNING_SECRET=change-me-in-production

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
